<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#2F5CFF"
                android:endColor="#1F4BFF"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#6EA2FF"
                android:endColor="#4B7BFF"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
</selector>
