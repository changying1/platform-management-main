<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!--    给入口卡片一个柔和的紫色渐变背景，提升质感。-->

    <!-- 圆角（和卡片圆角一致更柔和） -->
