<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 外层柔和“阴影感”（用半透明边缘模拟） -->
    <item>
        <shape>
            <solid android:color="#0A2F5CFF"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>

    <!-- 内层主体 -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape>
            <solid android:color="#CCFFFFFF"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1dp" android:color="#DDE7FF"/>
        </shape>
    </item>

</layer-list>
