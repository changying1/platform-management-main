<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="MyBottomNavigationViewStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconSize">26dp</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>

        <!-- 关键：选中/未选中同一套文字样式，避免缩放导致模糊 -->
        <item name="itemTextAppearanceActive">@style/MyBottomNavText</item>
        <item name="itemTextAppearanceInactive">@style/MyBottomNavText</item>

        <!-- 始终显示文字 -->
        <item name="labelVisibilityMode">labeled</item>

        <!-- 关键：不要用 itemBackground 去铺满整个 item（容易把布局撑变形）
             我们改用 itemRippleColor + 自己的 active indicator -->
        <item name="itemRippleColor">@color/bottom_nav_ripple</item>

    </style>

    <style name="MyBottomNavText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">14sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>


    <style name="MyIndicatorShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="BottomNavText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>
