<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_fence"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 地图 -->
    <com.amap.api.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 顶部悬浮操作条（圆角半透明卡片） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/top_action_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="10dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A000000"
        android:backgroundTint="#EFFFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_list"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="列表"
                android:textAllCaps="false"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconPadding="8dp"
                app:iconGravity="textStart"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="新增"
                android:textAllCaps="false"
                app:icon="@android:drawable/ic_input_add"
                app:iconPadding="8dp"
                app:iconGravity="textStart"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_locate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="定位"
                android:textAllCaps="false"
                app:icon="@android:drawable/ic_menu_mylocation"
                app:iconPadding="8dp"
                app:iconGravity="textStart"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- 新增/编辑围栏面板（底部圆角卡片） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panel_add"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:visibility="gone"
        app:cardCornerRadius="18dp"
        app:cardElevation="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="#14000000"
        android:backgroundTint="#FFFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="新增围栏"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="10dp"/>

                <!-- 围栏名称 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="围栏名称">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_fence_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 形状选择 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#14000000"
                    android:backgroundTint="#FAFAFA">

                    <RadioGroup
                        android:id="@+id/rg_shape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="10dp">

                        <RadioButton
                            android:id="@+id/rb_circle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="圆形"/>

                        <RadioButton
                            android:id="@+id/rb_polygon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:text="多边形"/>
                    </RadioGroup>
                </com.google.android.material.card.MaterialCardView>

                <!-- 圆形参数 -->
                <LinearLayout
                    android:id="@+id/group_circle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="半径（米）">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_fence_radius"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="50"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <SeekBar
                        android:id="@+id/sb_radius"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:max="20000"
                        android:progress="50"/>
                </LinearLayout>

                <!-- 多边形参数 -->
                <LinearLayout
                    android:id="@+id/group_polygon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_undo"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:text="撤销最后一点"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_revert"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="清空"
                        android:textAllCaps="false"
                        app:icon="@android:drawable/ic_menu_delete"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart"/>
                </LinearLayout>

                <!-- 行为 + 启用 -->
                <LinearLayout
                    android:id="@+id/group_behavior"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tv_behavior_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="触发行为"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp"/>

                    <Spinner
                        android:id="@+id/sp_trigger_type"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/sw_enable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="启用"
                    android:checked="true"
                    android:layout_marginTop="8dp"/>

                <!-- 底部操作 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:text="取消"
                        android:textAllCaps="false"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="保存"
                        android:textAllCaps="false"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="6dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>


    <!-- 列表面板（全屏半透明底 + 白色内容卡片） -->
    <FrameLayout
        android:id="@+id/panel_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#66000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="14dp"
            android:backgroundTint="#FFFFFFFF">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- 标题栏 -->
                <TextView
                    android:id="@+id/tv_list_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="围栏列表"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:padding="14dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_close_list"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_close_list"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关闭"
                    android:textAllCaps="false"
                    android:paddingEnd="10dp"
                    android:paddingStart="10dp"
                    app:layout_constraintTop_toTopOf="@id/tv_list_title"
                    app:layout_constraintBottom_toBottomOf="@id/tv_list_title"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- 切换按钮栏 -->
                <LinearLayout
                    android:id="@+id/layout_list_tabs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingBottom="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_list_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_tab_fence"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="围栏"
                        android:textSize="13sp"
                        android:textAllCaps="false"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_tab_device"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="设备"
                        android:textSize="13sp"
                        android:textAllCaps="false"/>
                </LinearLayout>

                <!-- 围栏列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_fence"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:padding="10dp"
                    android:visibility="visible"
                    app:layout_constraintTop_toBottomOf="@id/layout_list_tabs"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- 设备列表 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_device"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:padding="10dp"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/layout_list_tabs"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- 调试模式按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_debug_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_compass"
        android:contentDescription="设备调试"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:backgroundTint="#3F51B5"/>

    <!-- 调试模式指示器 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_debug_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FF9800"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_pulse"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="调试模式"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
