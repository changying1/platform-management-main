<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="#14000000"
    android:backgroundTint="#FFFFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_fence_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="围栏名称"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/sw_fence_enable"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tv_fence_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="圆形 · 半径 50m · 禁入 · 违规 0"
            android:textSize="13sp"
            android:textColor="#8A000000"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/tv_fence_name"
            app:layout_constraintTop_toBottomOf="@id/tv_fence_name"
            app:layout_constraintEnd_toEndOf="@id/tv_fence_name"/>

        <!-- 可选：违规徽标（默认隐藏） -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_violation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="违规 3"
            android:visibility="gone"
            app:chipCornerRadius="10dp"
            app:chipBackgroundColor="#1AFF3B30"
            android:textColor="#FF3B30"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tv_fence_name"
            app:layout_constraintEnd_toStartOf="@id/sw_fence_enable"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_fence_enable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启用"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_arrow"/>

        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@android:drawable/ic_media_next"
            android:alpha="0.65"
            android:contentDescription="more"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/sw_fence_enable"
            app:layout_constraintBottom_toBottomOf="@id/sw_fence_enable"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
