<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/player_block"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="16:9">

        <androidx.media3.ui.PlayerView
            android:id="@+id/player_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:surface_type="texture_view"
            app:use_controller="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <FrameLayout
            android:id="@+id/ezviz_player_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_player_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_controls"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:background="#33000000"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_play"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/btn_fullscreen"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_fullscreen_enter"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="#FFFFFF" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/control_tabs"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/player_block"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/tab_presets"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="预置点"
            android:textSize="14sp" />

        <Button
            android:id="@+id/tab_ptz"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="PTZ"
            android:textSize="14sp" />

        <Button
            android:id="@+id/tab_ai"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="AI监控"
            android:textSize="14sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/control_panel_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/control_tabs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/panel_presets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="预置点管理"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_presets"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="刷新/选择"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_preset_add"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="添加当前"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_preset_clear"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="清空/删除"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_presets_empty"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="暂无预置点"
                android:textColor="#888888"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_presets"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="巡航控制"
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cruise_start"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="启动巡航"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_cruise_stop"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="停止巡航"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_cruise_status"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="巡航状态"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_cruise_save"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="保存巡航"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_cruise_load"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="加载巡航"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_cruise_start_current"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="启动已保存"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/panel_ptz"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:foregroundGravity="center">

            <FrameLayout
                android:id="@+id/ptz_pad"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_ptz_circle"
                    android:clickable="false"
                    android:focusable="false" />

                <View
                    android:id="@+id/ptz_center"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_ptz_center"
                    android:clickable="false"
                    android:focusable="false" />

                <ImageButton
                    android:id="@+id/ptz_up"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="14dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="ptz_up"
                    android:focusable="true"
                    android:src="@drawable/ic_ptz_up"
                    app:tint="#9AA0AE" />

                <ImageButton
                    android:id="@+id/ptz_down"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="ptz_down"
                    android:focusable="true"
                    android:src="@drawable/ic_ptz_down"
                    app:tint="#9AA0AE" />

                <ImageButton
                    android:id="@+id/ptz_left"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="ptz_left"
                    android:focusable="true"
                    android:src="@drawable/ic_ptz_left"
                    app:tint="#9AA0AE" />

                <ImageButton
                    android:id="@+id/ptz_right"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="ptz_right"
                    android:focusable="true"
                    android:src="@drawable/ic_ptz_right"
                    app:tint="#9AA0AE" />

            </FrameLayout>

            <LinearLayout
                android:id="@+id/zoom_controls"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_zoom_out"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:text="-"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/btn_zoom_in"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="16dp"
                    android:text="+"
                    android:textSize="22sp" />

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:id="@+id/panel_ai"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI监测功能"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/ai_rule_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <TextView
                android:id="@+id/tv_ai_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="状态：未启动"
                android:textColor="#333333"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_ai_save_rules"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="保存配置"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_ai_start"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="启动监测"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_ai_stop"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="停止监测"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
